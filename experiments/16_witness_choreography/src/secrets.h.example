// secrets.h — Wi-Fi credentials + API endpoints. Copy this to secrets.h
// (gitignored) and fill in real values. NEVER commit secrets.h.
#pragma once

// Per-sculpture identity. Used as the SoftAP SSID during captive-portal
// onboarding, the captive-portal page heading, and the boot banner. Each
// unit's firmware build carries its own name (e.g. "Orbital Witness 1/12").
#define SCULPTURE_NAME "Orbital Witness 1/12"

// Wi-Fi credentials.
//
// Production: keep these as the placeholders below. On first boot the
// sculpture will raise its own SoftAP named SCULPTURE_NAME and serve a
// captive-portal setup page on http://192.168.4.1/ — the user picks
// their network and enters the password from a phone, the sculpture
// stores them in NVS and reboots into station mode.
//
// Developer convenience: if you put real creds here, they're used as
// a fallback when NVS is empty (so reflashing dev hardware doesn't
// always force you through the portal). To bypass the fallback and
// force portal-mode, leave WIFI_SSID as the placeholder "PROVISION_ME".
#define WIFI_SSID      "PROVISION_ME"
#define WIFI_PASSWORD  ""

// Schedule webservice. Returns 24 h of (t, az, el) samples. See
// orbitaltemple-ws/functions/src/schedule.ts for the contract.
#define SCHEDULE_URL_BASE  "https://orbital-temple.web.app/api/schedule"

// Observer location for THIS sculpture. The visualization uses Brooklyn
// coordinates and the schedule API takes lat/lon as query params.
// TODO: auto-detect via IP geolocation on first connect.
#define OBSERVER_LAT   40.65f
#define OBSERVER_LON  -73.95f
